## Part 4: Power Analysis

# Set Up Simulation Function (Power Analysis for Gregor's and Comparison w/ Tukey's HSD)
simulate_power <- function(delta, I = 5, J = 10, sigma = 1, n_sim = 1000, alpha = 0.05) {
	correct_rejections <- 0
	tukey_rejections <- 0

  	# Count the four possible outcomes:
  	both_reject <- 0	# Both Gregor and Tukey reject
  	gregor_only <- 0	# Only Gregor rejects
  	tukey_only <- 0		# Only Tukey rejects
  	neither <- 0		# Neither reject

	for (sim in 1:n_sim) {
	# Generate data under H0 (means 1,2,3 = 0)
	dataH0 <- matrix(rnorm(3*10, mean = 0, sd = sigma), nrow = 3, ncol = 10)
	# Generate data under HA (means 4,5 = Delta)
	dataHA <- matrix(rnorm(2*10, mean = delta, sd = sigma), nrow = 2, ncol = 10)

	# Combine Data and Calculate Summary Statistics
	data2 <- rbind(dataH0,dataHA)
	means2 <- rowMeans(data2)
	MSE2 <- mean(apply(data2, 1, var))

	# Apply Gregor's Comparison
	power_results <- greg_comparison(means2, 10, MSE2, alpha = 0.05)

	# Check if 4th Mean != 1st Mean
	if (power_results$significant[3] == "TRUE") {
	correct_rejections <- correct_rejections + 1
	}

	# Reframe Data to Use Tukey's HSD
	data2a <- data.frame(
		Mean = rep(c("1","2","3","4","5"), each = 10),
		Value = c(data2[1,],data2[2,],data2[3,],data2[4,],data2[5,])
		)

	# Apply Tukey's HSD
	anova <- aov(Value ~ Mean, data = data2a)
	tukey_results <- TukeyHSD(anova, conf.level = 0.95)
	
	# Check if 4th Mean != 1st Mean
	if (tukey_results$Mean[3,4]<0.05) {
	tukey_rejections <- tukey_rejections + 1
	}

	# Calculate Statistical Significance Between Gregor and Tukey Power
	gregor_sig <- (power_results$significant[3] == "TRUE")
	tukey_sig <- (tukey_results$Mean[3,4] < 0.05)

		if(gregor_sig & tukey_sig) {both_reject <- both_reject +1}
		if(gregor_sig & !tukey_sig) {gregor_only <- gregor_only + 1}
		if(!gregor_sig & tukey_sig) {tukey_only <- tukey_only +1}
		if(!gregor_sig & !tukey_sig) {neither <- neither +1}
	}	

	# McNemar's test
 	contingency <- matrix(c(both_reject, gregor_only, tukey_only, neither), nrow = 2)
 	result <- mcnemar.test(contingency)
	

return(c((correct_rejections / n_sim),(tukey_rejections / n_sim),result$p.value))
}

