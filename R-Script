# Gregor's Comparison is an alternate multiple comparisons method #
# to test for significant differences between pairings of means.  #
# The comparison takes a more liberal approach to the Bonferroni  #
# Correction by artificially raising the degrees of freedom used  #
# in calculating the t critical value. The method is excellent in #
# controlling the FWER to an acceptable range, and it is, for the #
# most part, on par with the power of Tukey's HSD.                #
#=================================================================#

## Parts 1 & 2: Designing and Implementing Gregor's Comparison

greg_comparison <- function(means, J, MSE, alpha = 0.05) {
# means: vector of sample means
# J: number of observations per group
# MSE: mean square error from ANOVA
# alpha: significance level
	diffmat <- outer(means,means,"-")
# Gregor's Comparison:
# Alpha given same tweak as Bonferroni
# Tweak the degrees of freedom (Increase but control for values of I and J)
	I <- length(means)
	N <- factorial(I)/(2*factorial(I-2))
	SE <- sqrt((2*MSE)/J)
	golden <- (1+sqrt(5))/2
	acrit <- (alpha/(N))
	t_crit <- qt(1-(acrit/2), df = (golden * ((I*(J-1))) + I^2) / sqrt(J/10))
# Gregor's Significant Difference
	GSD <- t_crit*SE
# Prep for Data Frame
	# Create Differences Vector
		diff <- c()				
		for (i in 2:I) {
		newdiff <- diffmat[i:I,(i-1)]
		diff <- c(diff,newdiff)}
	# Create Group 1 Vector
		g1 <- c()
		for (i in 1:I) {
		addg1 <- rep(means[i], times = I-i)
		g1 <- c(g1,addg1)}
	# Create Group 2 Vector
		g2 <- c()
		for (i in 2:I) {
		addg2 <- means[c(i:I)]
		g2 <- c(g2,addg2)}
	# Create Significance Vector
		sig <- c()
		for (i in 1:N) {
		out <- c(ifelse(abs(diff[i])>GSD,TRUE,FALSE))
		sig <- c(sig,out)}
# Construct the data frame displaying significant differences
	# Comp: tracks the number of comparisons made
	# Group 1, Group 2: the pair being compared
	# Diff: the difference in means
	# Significant: either TRUE (significant) or FALSE (not significant)
	comparisons <- data.frame(
				Comp = 1:N,
				group1 = g1,
				group2 = g2,
				diff = diff,
				significant = sig)
# Returns a data frame displaying all differences and their significance
	return(comparisons)
	}

# Demonstration with Example 11.5 (Oil Filters)
means <- c(14.5,13.8,13.3,14.3,13.1)
greg_comparison(means, J = 9, MSE = 0.088, alpha = 0.05)
	# Gregor's Comparison determined that the only non-significant differences were
		# between Brands 1 & 4 and 3 & 5. Brand 2 is significantly different
		# from all other brands.


## Part 3: Validating Gregor's Comparison via Simulation

# Set Up Simulation Function
simulate_fwer <- function(I, J, sigma = 1, n_sim = 10000, alpha = 0.05) {
	false_rejections <- 0

	for (sim in 1:n_sim) {
	# Generate data under H0 (all means = 0)
	data <- matrix(rnorm(I*J, mean = 0, sd = sigma), nrow = I, ncol = J)
	
	# Calculate summary statistics
	means <- rowMeans(data)
	MSE <- mean(apply(data, 1, var))  # Simplified; use pooled variance

	# Apply Gregor's Comparison
	results <- greg_comparison(means, J, MSE, alpha = 0.05)

	# Check if any rejection occurred
	if (any(results$significant == "TRUE")) {
	false_rejections <- false_rejections + 1
	}
	}

return(false_rejections / n_sim)
}

